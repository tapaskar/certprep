{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "toonnews",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["/Volumes/wininstall/toonnews/run-dev.sh"],
